{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/unified_listing.schema.json",
  "title": "UnifiedJapaneseRealEstateListingResult",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "source", "query", "items", "errors"],
  "properties": {
    "schema_version": { "type": "string", "const": "2026-04-26" },
    "source": { "type": "string", "enum": ["suumo", "athome", "homes", "yahoo_japan"] },
    "query": { "type": "object" },
    "items": { "type": "array", "items": { "$ref": "#/$defs/listing" } },
    "errors": { "type": "array", "items": { "$ref": "#/$defs/extraction_error" } }
  },
  "$defs": {
    "nullable_string": { "type": ["string", "null"] },
    "nullable_number": { "type": ["number", "null"] },
    "nullable_integer": { "type": ["integer", "null"] },
    "listing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "source",
        "source_listing_id",
        "source_url",
        "source_site_name",
        "fetched_at",
        "listing_status",
        "title",
        "property_type",
        "property_subtype",
        "transaction_type",
        "price_jpy",
        "price_text",
        "price_per_sqm_text",
        "management_fee_jpy",
        "management_fee_text",
        "repair_reserve_fund_jpy",
        "repair_reserve_fund_text",
        "repair_reserve_fund_initial_text",
        "other_fee_text",
        "deposit_key_money_text",
        "expected_annual_rent_text",
        "gross_yield_text",
        "address",
        "prefecture",
        "city",
        "ward",
        "town",
        "latitude",
        "longitude",
        "nearest_stations",
        "building_name",
        "room_number",
        "layout",
        "floor_area_sqm",
        "floor_area_text",
        "land_area_sqm",
        "land_area_text",
        "balcony_area_sqm",
        "balcony_area_text",
        "building_area_sqm",
        "building_area_text",
        "area_measurement_method",
        "floor",
        "total_floors",
        "basement_floors",
        "structure",
        "built_year",
        "built_month",
        "age_text",
        "total_units",
        "units_for_sale",
        "orientation",
        "parking",
        "rights",
        "zoning",
        "current_status",
        "building_status",
        "delivery_time",
        "management_form",
        "management_staff",
        "management_company",
        "construction_company",
        "defect_warranty",
        "defect_insurance",
        "certifications",
        "reform_renovation",
        "energy_performance",
        "insulation_performance",
        "estimated_utility_cost",
        "features",
        "equipment",
        "remarks",
        "recommended_comment",
        "sale_schedule",
        "event_info",
        "agency_name",
        "agency_phone",
        "agency_address",
        "agency_business_hours",
        "agency_holidays",
        "agency_license",
        "agency_transaction_type",
        "contact_url",
        "images",
        "floor_plan_images",
        "media",
        "image_count",
        "detail_text",
        "source_published_at",
        "source_updated_at",
        "next_update_at",
        "transaction_valid_until",
        "source_structured_fields",
        "search_metadata",
        "raw"
      ],
      "properties": {
        "id": { "type": "string" },
        "source": { "type": "string", "enum": ["suumo", "athome", "homes", "yahoo_japan"] },
        "source_listing_id": { "$ref": "#/$defs/nullable_string" },
        "source_url": { "$ref": "#/$defs/nullable_string" },
        "source_site_name": { "$ref": "#/$defs/nullable_string" },
        "fetched_at": { "$ref": "#/$defs/nullable_string" },
        "listing_status": { "$ref": "#/$defs/nullable_string" },
        "title": { "$ref": "#/$defs/nullable_string" },
        "property_type": { "$ref": "#/$defs/nullable_string" },
        "property_subtype": { "$ref": "#/$defs/nullable_string" },
        "transaction_type": { "$ref": "#/$defs/nullable_string" },
        "price_jpy": { "$ref": "#/$defs/nullable_integer" },
        "price_text": { "$ref": "#/$defs/nullable_string" },
        "price_per_sqm_text": { "$ref": "#/$defs/nullable_string" },
        "management_fee_jpy": { "$ref": "#/$defs/nullable_integer" },
        "management_fee_text": { "$ref": "#/$defs/nullable_string" },
        "repair_reserve_fund_jpy": { "$ref": "#/$defs/nullable_integer" },
        "repair_reserve_fund_text": { "$ref": "#/$defs/nullable_string" },
        "repair_reserve_fund_initial_text": { "$ref": "#/$defs/nullable_string" },
        "other_fee_text": { "$ref": "#/$defs/nullable_string" },
        "deposit_key_money_text": { "$ref": "#/$defs/nullable_string" },
        "expected_annual_rent_text": { "$ref": "#/$defs/nullable_string" },
        "gross_yield_text": { "$ref": "#/$defs/nullable_string" },
        "address": { "$ref": "#/$defs/nullable_string" },
        "prefecture": { "$ref": "#/$defs/nullable_string" },
        "city": { "$ref": "#/$defs/nullable_string" },
        "ward": { "$ref": "#/$defs/nullable_string" },
        "town": { "$ref": "#/$defs/nullable_string" },
        "latitude": { "$ref": "#/$defs/nullable_number" },
        "longitude": { "$ref": "#/$defs/nullable_number" },
        "nearest_stations": { "type": "array", "items": { "$ref": "#/$defs/station_access" } },
        "building_name": { "$ref": "#/$defs/nullable_string" },
        "room_number": { "$ref": "#/$defs/nullable_string" },
        "layout": { "$ref": "#/$defs/nullable_string" },
        "floor_area_sqm": { "$ref": "#/$defs/nullable_number" },
        "floor_area_text": { "$ref": "#/$defs/nullable_string" },
        "land_area_sqm": { "$ref": "#/$defs/nullable_number" },
        "land_area_text": { "$ref": "#/$defs/nullable_string" },
        "balcony_area_sqm": { "$ref": "#/$defs/nullable_number" },
        "balcony_area_text": { "$ref": "#/$defs/nullable_string" },
        "building_area_sqm": { "$ref": "#/$defs/nullable_number" },
        "building_area_text": { "$ref": "#/$defs/nullable_string" },
        "area_measurement_method": { "$ref": "#/$defs/nullable_string" },
        "floor": { "$ref": "#/$defs/nullable_integer" },
        "total_floors": { "$ref": "#/$defs/nullable_integer" },
        "basement_floors": { "$ref": "#/$defs/nullable_integer" },
        "structure": { "$ref": "#/$defs/nullable_string" },
        "built_year": { "$ref": "#/$defs/nullable_integer" },
        "built_month": { "$ref": "#/$defs/nullable_integer" },
        "age_text": { "$ref": "#/$defs/nullable_string" },
        "total_units": { "$ref": "#/$defs/nullable_integer" },
        "units_for_sale": { "$ref": "#/$defs/nullable_integer" },
        "orientation": { "$ref": "#/$defs/nullable_string" },
        "parking": { "$ref": "#/$defs/nullable_string" },
        "rights": { "$ref": "#/$defs/nullable_string" },
        "zoning": { "$ref": "#/$defs/nullable_string" },
        "current_status": { "$ref": "#/$defs/nullable_string" },
        "building_status": { "$ref": "#/$defs/nullable_string" },
        "delivery_time": { "$ref": "#/$defs/nullable_string" },
        "management_form": { "$ref": "#/$defs/nullable_string" },
        "management_staff": { "$ref": "#/$defs/nullable_string" },
        "management_company": { "$ref": "#/$defs/nullable_string" },
        "construction_company": { "$ref": "#/$defs/nullable_string" },
        "defect_warranty": { "$ref": "#/$defs/nullable_string" },
        "defect_insurance": { "$ref": "#/$defs/nullable_string" },
        "certifications": { "$ref": "#/$defs/nullable_string" },
        "reform_renovation": { "$ref": "#/$defs/nullable_string" },
        "energy_performance": { "$ref": "#/$defs/nullable_string" },
        "insulation_performance": { "$ref": "#/$defs/nullable_string" },
        "estimated_utility_cost": { "$ref": "#/$defs/nullable_string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "equipment": { "type": "array", "items": { "type": "string" } },
        "remarks": { "$ref": "#/$defs/nullable_string" },
        "recommended_comment": { "$ref": "#/$defs/nullable_string" },
        "sale_schedule": { "$ref": "#/$defs/nullable_string" },
        "event_info": { "$ref": "#/$defs/nullable_string" },
        "agency_name": { "$ref": "#/$defs/nullable_string" },
        "agency_phone": { "$ref": "#/$defs/nullable_string" },
        "agency_address": { "$ref": "#/$defs/nullable_string" },
        "agency_business_hours": { "$ref": "#/$defs/nullable_string" },
        "agency_holidays": { "$ref": "#/$defs/nullable_string" },
        "agency_license": { "$ref": "#/$defs/nullable_string" },
        "agency_transaction_type": { "$ref": "#/$defs/nullable_string" },
        "contact_url": { "$ref": "#/$defs/nullable_string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "floor_plan_images": { "type": "array", "items": { "type": "string" } },
        "media": { "type": "array", "items": { "$ref": "#/$defs/media_item" } },
        "image_count": { "$ref": "#/$defs/nullable_integer" },
        "detail_text": { "$ref": "#/$defs/nullable_string" },
        "source_published_at": { "$ref": "#/$defs/nullable_string" },
        "source_updated_at": { "$ref": "#/$defs/nullable_string" },
        "next_update_at": { "$ref": "#/$defs/nullable_string" },
        "transaction_valid_until": { "$ref": "#/$defs/nullable_string" },
        "source_structured_fields": { "type": "array", "items": { "$ref": "#/$defs/source_structured_field" } },
        "search_metadata": { "type": "object" },
        "raw": { "type": "object" }
      }
    },
    "station_access": {
      "type": "object",
      "additionalProperties": false,
      "required": ["line", "station", "walk_minutes", "bus_minutes", "text"],
      "properties": {
        "line": { "$ref": "#/$defs/nullable_string" },
        "station": { "$ref": "#/$defs/nullable_string" },
        "walk_minutes": { "$ref": "#/$defs/nullable_integer" },
        "bus_minutes": { "$ref": "#/$defs/nullable_integer" },
        "text": { "$ref": "#/$defs/nullable_string" }
      }
    },
    "media_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "url", "caption"],
      "properties": {
        "kind": { "$ref": "#/$defs/nullable_string" },
        "url": { "$ref": "#/$defs/nullable_string" },
        "caption": { "$ref": "#/$defs/nullable_string" }
      }
    },
    "source_structured_field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["section", "label", "value", "normalized_field_hint"],
      "properties": {
        "section": { "$ref": "#/$defs/nullable_string" },
        "label": { "type": "string" },
        "value": { "$ref": "#/$defs/nullable_string" },
        "normalized_field_hint": { "$ref": "#/$defs/nullable_string" }
      }
    },
    "extraction_error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "message"],
      "properties": {
        "url": { "$ref": "#/$defs/nullable_string" },
        "message": { "type": "string" }
      }
    }
  }
}
